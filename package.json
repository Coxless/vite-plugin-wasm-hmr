{
	"name": "vite-plugin-wasm-hmr",
	"version": "0.1.0",
	"type": "module",
	"description": "Vite plugin that watches Rust files, rebuilds with wasm-pack, and triggers HMR. Companion to vite-plugin-wasm.",
	"license": "MIT",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"format": "biome format --write",
		"lint": "biome lint",
		"check": "biome check --write --unsafe ."
	},
	"peerDependencies": {
		"vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.0.0",
		"vite": "^8.0.0",
		"vitest": "^4.1.2"
	}
}
