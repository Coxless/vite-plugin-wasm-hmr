{
	"name": "vite-plugin-wasm-hotreload",
	"version": "0.1.0",
	"type": "module",
	"description": "Vite plugin for wasm-pack hot module reload",
	"license": "MIT",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"format": "biome format --write",
		"lint": "biome lint",
		"check": "biome check --write --unsafe ."
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.0.0",
		"vite": "^8.0.0"
	}
}
